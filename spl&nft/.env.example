# Solana Cluster Configuration
# Options: devnet, testnet, mainnet-beta
SOLANA_CLUSTER=devnet

# RPC Endpoint (optional - uses default if not set)
# SOLANA_RPC_URL=https://api.devnet.solana.com

# Keypair path (path to your Solana wallet keypair JSON file)
# Generate one with: solana-keygen new --outfile ~/my-keypair.json
KEYPAIR_PATH=/path/to/keypair.json

# Token Configuration
TOKEN_DECIMALS=9
TOKEN_NAME=My Token
TOKEN_SYMBOL=MYTOKEN

# NFT Configuration
NFT_NAME=My NFT
NFT_SYMBOL=MYNFT
NFT_URI=https://example.com/metadata.json
